# Rename this file to .env or create a new .env file with your API keys
OPENAI_API_KEY=your-openai-api-key-here
GROQ_API_KEY=your-groq-api-key-here

# To use Groq for STT instead of OpenAI, set EX_API=true
EX_API=false

# To use local faster-whisper instead of APIs, set USE_LOCAL_STT=true
# (This requires installing faster-whisper and Microsoft Visual C++ Build Tools)
USE_LOCAL_STT=true
