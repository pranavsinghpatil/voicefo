# API Keys
OPENAI_API_KEY=your-openai-api-key-here
GROQ_API_KEY=your-groq-api-key-here

# STT Engine: Groq is near-instant. Set USE_LOCAL_STT=true only if faster-whisper+GPU is available.
USE_LOCAL_STT=false
USE_GROQ_API=true

# LLM Engine: Use Groq API (fast). Set USE_API_LLM=false to use local Ollama instead.
USE_API_LLM=true
LOCAL_LLM_MODEL=qwen3.5:latest
